@model OnlineStore.WebUI.Models.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Am uitat parola";
}

<style>
    .auth-page {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: calc(100vh - 350px);
        padding: 2rem 1rem;
    }

    .auth-card {
        background: #fff;
        border: 1px solid var(--border-light);
        border-radius: 20px;
        padding: 2rem 2.5rem;
        width: 100%;
        max-width: 380px;
        box-shadow: 0 10px 50px rgba(0, 0, 0, 0.05);
        text-align: center;
    }

    .auth-logo {
        width: 36px;
        height: 36px;
        background: var(--text-dark);
        color: var(--accent-green);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1rem;
        font-size: 1rem;
    }

    .auth-title {
        font-family: var(--font-serif);
        font-size: 1.375rem;
        letter-spacing: -0.02em;
        margin-bottom: 0.25rem;
    }

    .auth-subtitle {
        color: var(--text-muted);
        font-size: 0.8125rem;
        margin-bottom: 1.25rem;
    }

    .form-group {
        text-align: left;
        margin-bottom: 1rem;
        position: relative;
    }

    .form-label {
        font-size: 0.65rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--text-muted);
        margin-bottom: 0.4rem;
        display: block;
    }

    .form-control {
        width: 100%;
        background: var(--bg-warm);
        border: 1.5px solid transparent;
        border-radius: 10px;
        padding: 0.65rem 1rem;
        font-family: var(--font-main);
        font-size: 0.875rem;
        color: var(--text-dark);
        transition: var(--transition);
        outline: none;
    }

    .form-control:focus {
        background: #fff;
        border-color: var(--accent-green);
        box-shadow: 0 0 0 5px rgba(45, 106, 79, 0.1);
    }

    .btn-submit {
        width: 100%;
        background: var(--text-dark);
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: 0.75rem;
        font-size: 0.875rem;
        font-weight: 700;
        cursor: pointer;
        transition: var(--transition);
        margin-bottom: 1rem;
    }

    .btn-submit:hover {
        background: var(--accent-green);
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(45, 106, 79, 0.2);
    }

    .auth-link {
        font-weight: 600;
        color: var(--text-muted);
        font-size: 0.9375rem;
    }

    .auth-link strong {
        color: var(--accent-green);
    }

    .validation-summary {
        margin-bottom: 2rem;
        padding: 1rem;
        background: #fff1f2;
        border: 1px solid #fecaca;
        border-radius: 12px;
        color: #991b1b;
        font-size: 0.875rem;
        font-weight: 500;
    }

    .validation-summary ul {
        list-style: none;
    }
</style>

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-logo">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
            </svg>
        </div>

        <h1 class="auth-title">Recuperare parolă</h1>
        <p class="auth-subtitle">Introdu adresa de email pentru a primi codul de resetare.</p>

        @if (!ViewContext.ViewData.ModelState.IsValid)
        {
            <div asp-validation-summary="All" class="validation-summary"></div>
        }

        <form asp-action="ForgotPassword" method="post">
            <div class="form-group">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" class="form-control" placeholder="exemplu@mail.com" required />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <button type="submit" class="btn-submit">Trimite Codul</button>
        </form>

        <a asp-action="Login" class="auth-link">Înapoi la <strong>Autentificare</strong></a>
    </div>
</div>

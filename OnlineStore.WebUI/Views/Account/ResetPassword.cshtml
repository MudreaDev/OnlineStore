@model OnlineStore.WebUI.Models.ResetPasswordViewModel
@{
    ViewData["Title"] = "Resetare parolă";
}

<style>
    .auth-page {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: calc(100vh - 350px);
        padding: 2rem 1rem;
    }

    .auth-card {
        background: #fff;
        border: 1px solid var(--border-subtle);
        border-radius: 20px;
        padding: 2rem 2.5rem;
        width: 100%;
        max-width: 380px;
        box-shadow: 0 10px 50px rgba(0, 0, 0, 0.05);
        text-align: center;
    }

    .auth-logo {
        width: 36px;
        height: 36px;
        background: var(--midnight);
        color: var(--accent-primary);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1rem;
        font-size: 1rem;
    }

    .auth-title {
        font-family: var(--font-elegant);
        font-size: 1.375rem;
        color: var(--midnight);
        letter-spacing: -0.02em;
        margin-bottom: 0.25rem;
    }

    .auth-subtitle {
        color: var(--text-muted);
        font-size: 0.8125rem;
        margin-bottom: 1.25rem;
    }

    .form-group {
        text-align: left;
        margin-bottom: 1rem;
        position: relative;
    }

    .form-label {
        font-size: 0.65rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--text-muted);
        margin-bottom: 0.4rem;
        display: block;
    }

    .form-control {
        width: 100%;
        background: var(--bg-base);
        border: 1.5px solid transparent;
        border-radius: 10px;
        padding: 0.65rem 1rem;
        font-family: var(--font-body);
        font-size: 0.875rem;
        color: var(--midnight);
        transition: var(--transition-smooth);
        outline: none;
    }

    .form-control:focus {
        background: #fff;
        border-color: var(--accent-primary);
        box-shadow: 0 0 0 5px rgba(5, 150, 105, 0.1);
    }

    .btn-submit {
        width: 100%;
        background: var(--midnight);
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: 0.75rem;
        font-size: 0.875rem;
        font-weight: 700;
        cursor: pointer;
        transition: var(--transition-smooth);
        margin-bottom: 1rem;
    }

    .btn-submit:hover {
        background: var(--accent-primary);
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(5, 150, 105, 0.2);
    }

    .auth-link {
        font-weight: 600;
        color: var(--text-muted);
        font-size: 0.9375rem;
    }

    .auth-link strong {
        color: var(--accent-primary);
    }

    .validation-summary {
        margin-bottom: 2rem;
        padding: 1rem;
        background: #fff1f2;
        border: 1px solid #fecaca;
        border-radius: 12px;
        color: #991b1b;
        font-size: 0.875rem;
        font-weight: 500;
    }

    .validation-summary ul {
        list-style: none;
    }
    
    .otp-input {
        letter-spacing: 0.5rem;
        text-align: center;
        font-size: 1.25rem;
        font-weight: bold;
    }
</style>

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-logo">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
            </svg>
        </div>

        <h1 class="auth-title">Setați noua parolă</h1>
        <p class="auth-subtitle">Introduceți codul primit pe email și noua parolă.</p>

        @if (!ViewContext.ViewData.ModelState.IsValid)
        {
            <div asp-validation-summary="All" class="validation-summary"></div>
        }

        <form asp-action="ResetPassword" method="post">
            <input type="hidden" asp-for="Email" />
            
            <div class="form-group">
                <label asp-for="Code" class="form-label">Cod de resetare</label>
                <input asp-for="Code" class="form-control otp-input" placeholder="000000" maxlength="6" required />
                <span asp-validation-for="Code" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="NewPassword" class="form-label">Parola nouă</label>
                <input asp-for="NewPassword" class="form-control" type="password" placeholder="••••••••" required />
                <span asp-validation-for="NewPassword" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="ConfirmPassword" class="form-label">Confirmare parolă</label>
                <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="••••••••" required />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="btn-submit">Resetează Parola</button>
        </form>

        <a asp-action="Login" class="auth-link">Înapoi la <strong>Autentificare</strong></a>
    </div>
</div>

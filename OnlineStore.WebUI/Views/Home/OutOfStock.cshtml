@model List<OnlineStore.Domain.Entities.Product>
@using OnlineStore.Domain.Singleton

@{
    ViewData["Title"] = "Inventory Archive";
}

<style>
    .archive-header {
        margin-bottom: 4rem;
        text-align: center;
        max-width: 600px;
        margin-left: auto;
        margin-right: auto;
    }

    .archive-title {
        font-family: var(--font-display);
        font-size: 3.5rem;
        font-weight: 800;
        color: var(--midnight);
        margin-bottom: 1rem;
        letter-spacing: -0.03em;
    }

    .archive-subtitle {
        font-size: 1.125rem;
        color: var(--text-muted);
        line-height: 1.6;
    }

    .product-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 3rem;
        margin-bottom: 6rem;
    }

    .product-card {
        background: #fff;
        border: 1px solid var(--border-subtle);
        border-radius: 28px;
        overflow: hidden;
        transition: var(--transition-smooth);
        position: relative;
        box-shadow: var(--shadow-sm);
    }

    .product-card:hover {
        transform: translateY(-8px);
        box-shadow: var(--shadow-lg);
        border-color: var(--accent-primary);
    }

    .status-badge {
        position: absolute;
        top: 1.25rem;
        right: 1.25rem;
        background: #dc2626;
        color: #fff;
        padding: 0.35rem 0.85rem;
        border-radius: 99px;
        font-size: 0.65rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        z-index: 10;
        box-shadow: 0 4px 12px rgba(220, 38, 38, 0.2);
    }

    .card-img-wrapper {
        aspect-ratio: 1/1;
        background: var(--bg-base);
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .card-img-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0.6;
        filter: grayscale(40%);
        transition: var(--transition-smooth);
    }

    .product-card:hover .card-img-wrapper img {
        opacity: 0.8;
        transform: scale(1.05);
    }

    .card-body {
        padding: 2rem;
    }

    .card-name {
        font-family: var(--font-display);
        font-size: 1.25rem;
        font-weight: 800;
        color: var(--midnight);
        margin-bottom: 0.5rem;
    }

    .card-price {
        font-size: 1.125rem;
        color: var(--text-muted);
        font-weight: 600;
    }

    .card-footer {
        margin-top: 1.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--border-subtle);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--accent-primary);
        font-size: 0.875rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    /* --- Back Nav styling --- */
    .back-nav {
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 0.8125rem;
        font-weight: 700;
        color: var(--text-muted);
        text-decoration: none;
        transition: var(--transition-smooth);
        margin-bottom: 2rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    .back-nav:hover {
        color: var(--accent-primary);
        transform: translateX(-5px);
    }

    .empty-state {
        text-align: center;
        padding: 8rem 2rem;
        background: #fff;
        border-radius: 32px;
        border: 1px solid var(--border-subtle);
        box-shadow: var(--shadow-md);
    }

    .empty-icon {
        font-size: 4rem;
        margin-bottom: 1.5rem;
        opacity: 0.3;
    }
</style>

<div class="container fade-in" style="padding-top: 2rem;">
    <a asp-action="Index" class="back-nav">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        Back to collection
    </a>

    <header class="archive-header">
        <h1 class="archive-title">Archive</h1>
        <p class="archive-subtitle">Exclusive pieces that are currently unavailable. Sign up to be the first to know when they return to our collection.</p>
    </header>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-icon">📂</div>
            <h3 class="card-name">Collection is Complete</h3>
            <p class="archive-subtitle">All our curated items are currently in stock and available for immediate shipping.</p>
            <a asp-action="Index" class="btn-bag-primary" style="display: inline-flex; width: auto; margin-top: 2rem; padding: 1rem 2.5rem;">Explore Catalog</a>
        </div>
    }
    else
    {
        <div class="product-grid">
            @foreach (var product in Model)
            {
                var mainImage = product.Images.FirstOrDefault(i => i.IsMain) ?? product.Images.FirstOrDefault();
                <div class="product-card">
                    <span class="status-badge">Waitlist</span>
                    
                    <a asp-action="Details" asp-route-id="@product.Id" style="text-decoration: none; color: inherit;">
                        <div class="card-img-wrapper">
                            @if (mainImage != null)
                            {
                                <img src="@mainImage.ImageUrl" alt="@product.Name">
                            }
                            else
                            {
                                <div style="font-size: 4rem; opacity: 0.2;">📦</div>
                            }
                        </div>
                        
                        <div class="card-body">
                            <h3 class="card-name">@product.Name</h3>
                            <div class="card-price">@ApplicationConfigurationManager.Instance.CurrencySymbol@product.Price.ToString("N0")</div>
                            
                            <div class="card-footer">
                                <span>Notify Me</span>
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                                    <line x1="5" y1="12" x2="19" y2="12"></line>
                                    <polyline points="12 5 19 12 12 19"></polyline>
                                </svg>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    }
</div>

@using OnlineStore.Domain.DesignPatterns.Structural.Composite
@model ProductCategory

@{
    ViewData["Title"] = "Catalog Produse (Composite Pattern)";
}

<style>
    .catalog-page {
        padding-top: 3rem;
        padding-bottom: 8rem;
    }
    .catalog-title {
        font-family: var(--font-elegant);
        font-size: 2.25rem;
        color: var(--midnight);
        margin-bottom: 1rem;
    }
    .category-card {
        background: #fff;
        border: 1px solid var(--border-subtle);
        border-radius: 16px;
        padding: 2rem;
        margin-bottom: 2rem;
        box-shadow: var(--shadow-sm);
    }
    .category-title {
        font-family: var(--font-display);
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--midnight);
        margin-bottom: 1.5rem;
        border-bottom: 2px solid var(--border-subtle);
        padding-bottom: 0.5rem;
    }
    .products-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 1.5rem;
    }
    .product-item {
        background: var(--bg-base);
        border: 1px solid var(--border-subtle);
        border-radius: 12px;
        padding: 1rem;
        text-align: center;
        transition: var(--transition-smooth);
        text-decoration: none;
        color: inherit;
        display: block;
    }
    .product-item:hover {
        border-color: var(--accent-primary);
        transform: translateY(-5px);
        box-shadow: var(--shadow-md);
    }
    .product-img {
        width: 100%;
        height: 150px;
        object-fit: cover;
        border-radius: 8px;
        margin-bottom: 1rem;
    }
    .product-name {
        font-weight: 600;
        margin-bottom: 0.5rem;
        font-size: 0.95rem;
    }
    .product-price {
        color: var(--accent-primary);
        font-weight: 700;
        font-size: 0.9rem;
    }
</style>

<div class="container catalog-page fade-in">
    <h1 class="catalog-title">@Model.Name</h1>
    
    <div style="font-size: 1.125rem; font-weight: bold; margin-bottom: 3rem; background: var(--midnight); color: #fff; display: inline-block; padding: 1rem 2rem; border-radius: 12px; box-shadow: var(--shadow-md);">
        Valoare Totală Inventar: @Model.GetPrice().ToString("C2")
    </div>

    @foreach (var child in Model.Children)
    {
        if (child is ProductCategory subCategory)
        {
            <div class="category-card">
                <h2 class="category-title">
                    @subCategory.Name 
                    <span style="font-size: 0.9rem; color: var(--text-muted); float: right; font-weight: normal; background: var(--bg-base); padding: 0.25rem 0.75rem; border-radius: 20px;">
                        Valoare Categorie: <b>@subCategory.GetPrice().ToString("C2")</b>
                    </span>
                </h2>
                <div class="products-grid">
                    @foreach (var item in subCategory.Children)
                    {
                        if (item is ProductItem product)
                        {
                            <a href="@Url.Action("Details", "Home", new { id = product.ProductId })" class="product-item">
                                @if (!string.IsNullOrEmpty(product.ImageUrl))
                                {
                                    <img src="@product.ImageUrl" class="product-img" alt="@product.Name" />
                                }
                                else
                                {
                                    <div class="product-img" style="display: flex; align-items: center; justify-content: center; background: #f3f4f6; font-size: 2.5rem;">📦</div>
                                }
                                <div class="product-name">@product.Name</div>
                                <div class="product-price">@product.GetPrice().ToString("C2")</div>
                            </a>
                        }
                    }
                </div>
            </div>
        }
    }
</div>

@using OnlineStore.Domain.Entities
@inject OnlineStore.Application.Data.OnlineStoreDbContext _context
@{
    ViewData["Title"] = "Add Item";
    var categories = _context.Categories.ToList();
}

<style>
    .admin-form-container {
        width: 100%;
        max-width: 1100px;
        margin: 1rem auto 3rem;
        padding: 0 2rem;
    }

    .form-card {
        background: #fff;
        border: 1px solid var(--border-subtle);
        border-radius: 20px;
        padding: 2rem;
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
    }

    .form-header {
        margin-bottom: 2rem;
    }

    .form-title {
        font-family: var(--font-display);
        font-size: 1.75rem;
        font-weight: 800;
        color: var(--midnight);
        margin: 0;
    }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
    }

    .form-section-title {
        font-size: 0.75rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--accent-primary);
        margin-bottom: 1.25rem;
        display: block;
        border-bottom: 1px solid #f1f5f9;
        padding-bottom: 0.5rem;
    }

    .field-group {
        margin-bottom: 1rem;
    }

    .field-label {
        font-size: 0.8rem;
        font-weight: 700;
        color: #334155;
        margin-bottom: 0.5rem;
        display: block;
    }

    .premium-input {
        width: 100%;
        background: #f8fafc;
        border: 1.5px solid #e2e8f0;
        border-radius: 8px;
        padding: 0.5rem 0.75rem;
        font-size: 0.875rem;
        transition: 0.2s;
        outline: none;
    }

    .premium-input:focus {
        border-color: var(--accent-primary);
        background: #fff;
        box-shadow: 0 0 0 3px rgba(5, 150, 105, 0.05);
    }

    .type-container {
        background: #fdfdfd;
        border: 1px solid #f1f5f9;
        padding: 1.25rem;
        border-radius: 12px;
        margin-top: 1rem;
    }

    /* Images */
    .upload-area {
        border: 2px dashed #cbd5e1;
        border-radius: 12px;
        padding: 1.5rem;
        text-align: center;
        cursor: pointer;
        background: #f8fafc;
        transition: 0.2s;
    }

    .upload-area:hover {
        border-color: var(--accent-primary);
        background: #fff;
    }

    .preview-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
        gap: 0.75rem;
        margin-top: 1.5rem;
    }

    .thumb-box {
        position: relative;
        aspect-ratio: 1;
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid #e2e8f0;
    }

    .thumb-box img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .btn-submit {
        background: var(--midnight);
        color: #fff;
        border: none;
        padding: 1rem;
        border-radius: 10px;
        font-weight: 700;
        width: 100%;
        cursor: pointer;
        margin-top: 2rem;
        font-size: 0.9rem;
    }

    .btn-submit:hover {
        background: var(--accent-primary);
    }
</style>

<div class="admin-form-container">
    <div class="form-header">
        <h1 class="form-title">📦 New Inventory <span style="color: var(--accent-primary)">Item</span></h1>
    </div>

    <div class="form-card">
        <form asp-action="AddProduct" method="post" enctype="multipart/form-data">
            <div class="form-grid">
                <!-- Left Column: Core Info -->
                <div>
                    <span class="form-section-title">Core Identity</span>
                    
                    <div class="field-group">
                        <label class="field-label">Engine Classification</label>
                        <select name="Type" id="Type" class="premium-input" onchange="toggleFields()">
                            <option value="Dynamic">⚡ Dynamic Taxonomy (Custom Categories)</option>
                            <option value="Electronic">Electronic (Legacy)</option>
                            <option value="Clothing">Clothing (Legacy)</option>
                            <option value="Vehicle">Vehicle (Legacy)</option>
                        </select>
                    </div>

                    <div class="field-group">
                        <label class="field-label">Product Name</label>
                        <input type="text" name="Name" class="premium-input" placeholder="e.g. Minimalist Watch" required />
                    </div>

                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                        <div class="field-group">
                            <label class="field-label">Retail Price ($)</label>
                            <input type="number" name="Price" step="0.01" class="premium-input" placeholder="0.00" required />
                        </div>
                        <div class="field-group">
                            <label class="field-label">Opening Stock</label>
                            <input type="number" name="stock" class="premium-input" value="10" required />
                        </div>
                    </div>

                    <div class="field-group">
                        <label class="field-label">Color Palette (Comma CSV)</label>
                        <input type="text" name="availableColors" class="premium-input" placeholder="#000, #fff, #ef4444" />
                    </div>

                    <!-- Dynamic Sections -->
                    <div id="DynamicFields" class="type-container" style="border-top: 3px solid #0077cc;">
                        <span class="form-section-title" style="color:#0077cc">Taxonomy Mapping</span>
                        <div class="field-group">
                            <label class="field-label">Select Sub-Category</label>
                            <select name="subcategoryId" id="subcategoryId" class="premium-input" onchange="renderDynamicForm()">
                                <option value="">-- Choose Type --</option>
                                @inject OnlineStore.Application.Data.OnlineStoreDbContext _db
                                @{
                                    var subs = _db.SubCategories.Select(s => new { s.Id, s.Name, s.ExpectedAttributes }).ToList();
                                }
                                @foreach(var s in subs) {
                                    <option value="@s.Id" data-attrs="@s.ExpectedAttributes">@s.Name</option>
                                }
                            </select>
                        </div>
                        <div id="dynamicInputsContainer" style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem;"></div>
                    </div>

                    <div id="ElectronicFields" class="type-container" style="display:none;">
                        <span class="form-section-title" style="color:var(--midnight)">Electronic Specs</span>
                         <div class="field-group">
                            <label class="field-label">Warranty (Months)</label>
                            <input type="number" name="WarrantyMonths" class="premium-input" value="24" />
                        </div>
                    </div>

                    <div id="ClothingFields" class="type-container" style="display:none;">
                        <span class="form-section-title" style="color:var(--midnight)">Clothing Specs</span>
                         <div class="field-group">
                            <label class="field-label">Material</label>
                            <input type="text" name="material" class="premium-input" placeholder="Cotton, etc." />
                        </div>
                        <div class="field-group">
                            <label class="field-label">Available Sizes</label>
                            <input type="text" name="availableSizes" class="premium-input" placeholder="S, M, L" />
                        </div>
                    </div>

                    <div id="VehicleFields" class="type-container" style="display:none;">
                        <span class="form-section-title" style="color:var(--midnight)">Vehicle Specs</span>
                        <div class="input-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem;">
                            <input type="text" name="Brand" class="premium-input" placeholder="Brand" />
                            <input type="text" name="Model" class="premium-input" placeholder="Model" />
                            <input type="number" name="Year" class="premium-input" value="2024" style="grid-column: span 2" />
                        </div>
                    </div>
                </div>

                <!-- Right Column: Media -->
                <div>
                    <span class="form-section-title">Visual Assets & Media</span>
                    <div class="upload-area" onclick="document.getElementById('imageInput').click()">
                        <div style="font-size: 1.5rem; margin-bottom: 0.5rem;">☁</div>
                        <p style="font-weight: 700; font-size: 0.85rem; margin: 0;">Upload Galleries</p>
                        <p style="font-size: 0.7rem; color: var(--text-muted);">Max 5 files · Click to browse</p>
                    </div>
                    <input type="file" id="imageInput" multiple accept="image/*" style="display: none;" onchange="handleFileSelect(this)" />
                    <input type="hidden" name="mainImageIndex" id="mainImageIndex" value="0" />
                    
                    <div class="preview-grid" id="previewGrid"></div>

                    <div style="margin-top: 2rem; padding: 1rem; background: #fdfdfd; border: 1px solid #f1f5f9; border-radius: 12px;">
                        <p style="font-size: 0.7rem; color: var(--text-muted); line-height: 1.4; margin: 0;">
                            <strong>Pro Tip:</strong> Click on an uploaded image to set it as the <b>Primary Cover</b> for this item.
                        </p>
                    </div>

                    <button type="submit" class="btn-submit">Register Item in Inventory</button>
                </div>
            </div>
        </form>
    </div>
</div>

<script>
    function toggleFields() {
        const type = document.getElementById('Type').value;
        const sections = ['DynamicFields', 'ElectronicFields', 'ClothingFields', 'VehicleFields'];
        sections.forEach(s => {
            document.getElementById(s).style.display = s.startsWith(type) ? 'block' : 'none';
        });
    }

    function renderDynamicForm() {
        const select = document.getElementById('subcategoryId');
        const container = document.getElementById('dynamicInputsContainer');
        container.innerHTML = '';
        
        const option = select.options[select.selectedIndex];
        if(!option || !option.dataset.attrs) return;

        const attrs = option.dataset.attrs.split(',');
        attrs.forEach(attr => {
            const clean = attr.trim();
            if(!clean) return;
            const key = clean.replace(/\s+/g, '');
            container.innerHTML += `
                <div class="field-group">
                    <label class="field-label">${clean}</label>
                    <input type="text" name="dyn_${key}" class="premium-input" placeholder="..." />
                </div>
            `;
        });
    }

    let selectedFiles = [];
    let masterIdx = 0;

    function handleFileSelect(input) {
        const files = Array.from(input.files);
        selectedFiles = [...selectedFiles, ...files].slice(0, 5);
        updatePreview();
    }

    function updatePreview() {
        const container = document.getElementById('previewGrid');
        container.innerHTML = '';
        
        const dt = new DataTransfer();
        selectedFiles.forEach(f => dt.items.add(f));
        document.getElementById('imageInput').files = dt.files;
        document.getElementById('imageInput').name = "images";

        selectedFiles.forEach((file, idx) => {
            const reader = new FileReader();
            reader.onload = (e) => {
                const box = document.createElement('div');
                box.className = 'thumb-box';
                if(idx === masterIdx) box.style.borderColor = 'var(--accent-primary)';
                box.innerHTML = `
                    <img src="${e.target.result}" onclick="setMaster(${idx})" style="cursor:pointer">
                    <div onclick="removeFile(${idx})" style="position:absolute; top:2px; right:2px; background:rgba(0,0,0,0.5); color:#fff; width:16px; height:16px; font-size:10px; display:flex; align-items:center; justify-content:center; border-radius:50%; cursor:pointer">✕</div>
                `;
                container.appendChild(box);
            };
            reader.readAsDataURL(file);
        });
        document.getElementById('mainImageIndex').value = masterIdx;
    }

    function removeFile(idx) {
        selectedFiles.splice(idx, 1);
        if(masterIdx >= selectedFiles.length) masterIdx = 0;
        updatePreview();
    }

    function setMaster(idx) {
        masterIdx = idx;
        updatePreview();
    }

    // Initial state
    toggleFields();
</script>

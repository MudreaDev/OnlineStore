@using OnlineStore.Domain.Singleton
@using Microsoft.AspNetCore.Http
@using OnlineStore.WebUI.Extensions
@using OnlineStore.Domain.Entities
@using OnlineStore.Application.Repositories
@inject IHttpContextAccessor HttpContextAccessor
@inject DbUserRepository UserRepo

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @ApplicationConfigurationManager.Instance.StoreName</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Inter:wght@300;400;500;600;700&family=Outfit:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">

    <style>
        :root {
            --bg-base: #f9f7f2; /* Warm Beige */
            --surface: #ffffff;
            --accent-primary: #2d2926; /* Charcoal */
            --accent-secondary: #4a443f;
            --midnight: #2d2926;
            --text-main: #2d2926;
            --text-muted: #8c867e;
            --border-subtle: #eeebe6;
            --border-bold: #d6d2cc;
            --navbar-height: 70px;
            --font-display: 'Outfit', sans-serif;
            --font-body: 'Inter', sans-serif;
            --font-elegant: 'DM Serif Display', serif;
            --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
            --shadow-md: 0 4px 12px -2px rgb(0 0 0 / 0.08);
            --shadow-lg: 0 12px 24px -4px rgb(0 0 0 / 0.12);
            --transition-smooth: 0.4s cubic-bezier(0.25, 1, 0.5, 1);
            --bg-glass-header: rgba(249, 247, 242, 0.9);
            --bg-glass-input: rgba(255, 255, 255, 0.9);
        }

        :root.dark-theme {
            --bg-base: #121212;
            --surface: #1e1e1e;
            --accent-primary: #e5e5e5;
            --accent-secondary: #b3b3b3;
            --midnight: #f9f9f9;
            --text-main: #f3f4f6;
            --text-muted: #9ca3af;
            --border-subtle: #333333;
            --border-bold: #4b5563;
            --bg-glass-header: rgba(18, 18, 18, 0.9);
            --bg-glass-input: rgba(30, 30, 30, 0.9);
        }

        /* --- Side Cart Drawer --- */
        .cart-drawer-wrapper {
            position: fixed;
            top: 0;
            right: -450px;
            width: 400px;
            max-width: 100vw;
            height: 100vh;
            background: var(--bg-base);
            box-shadow: var(--shadow-lg);
            z-index: 2000;
            transition: right 0.4s cubic-bezier(0.25, 1, 0.5, 1);
            display: flex;
            flex-direction: column;
        }

        body.cart-open .cart-drawer-wrapper { right: 0; }
        body.cart-open .drawer-overlay { display: block; z-index: 1999;}

        @@keyframes fadeInUp {

            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .fade-in {
            animation: fadeInUp 0.6s ease-out forwards;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background-color: var(--bg-base);
            background-image: 
                radial-gradient(at 0% 0%, rgba(5, 150, 105, 0.03) 0, transparent 50%), 
                radial-gradient(at 50% 0%, rgba(6, 78, 59, 0.02) 0, transparent 50%),
                radial-gradient(at 100% 0%, rgba(5, 150, 105, 0.03) 0, transparent 50%);
            background-attachment: fixed;
            color: var(--text-main);
            font-family: var(--font-body);
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
            overflow-x: hidden;
            font-size: 0.9375rem;
        }

        .container {
            max-width: 1440px;
            margin: 0 auto;
            padding: 0 2rem;
        }

        /* --- Header: Glassmorphism --- */
        .site-header {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            height: var(--navbar-height);
            background: var(--bg-glass-header);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            z-index: 1000;
            display: flex;
            align-items: center;
            border-bottom: 1px solid var(--border-subtle);
            transition: var(--transition-smooth);
        }

        .navbar {
            display: grid;
            grid-template-columns: auto 1fr auto;
            align-items: center;
            gap: 3rem;
            width: 100%;
        }

        .logo {
            font-family: var(--font-elegant);
            font-size: 1.25rem;
            color: var(--midnight);
            text-decoration: none;
            display: flex;
            align-items: center;
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }

        /* Search & Filters: Refined Glow */
        .nav-search-form {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            max-width: 700px;
            width: 100%;
            margin: 0 auto;
        }

        .search-input-wrap {
            position: relative;
            flex: 1;
        }

        .nav-search-input {
            width: 100%;
            background: var(--bg-glass-input);
            border: 1px solid var(--border-bold);
            border-radius: 12px;
            padding: 0.5rem 1rem 0.5rem 2.75rem;
            font-size: 0.8125rem;
            font-family: var(--font-body);
            transition: var(--transition-smooth);
        }

        .nav-search-input:focus {
            outline: none;
            border-color: var(--accent-primary);
            box-shadow: 0 0 0 4px rgba(5, 150, 105, 0.08);
            background: var(--surface);
        }

        .search-icon {
            position: absolute;
            left: 1rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
            pointer-events: none;
        }

        .nav-select {
            background: var(--bg-glass-input);
            border: 1px solid var(--border-bold);
            border-radius: 12px;
            padding: 0.625rem 1rem;
            font-size: 0.8125rem;
            font-weight: 600;
            color: var(--text-main);
            cursor: pointer;
            min-width: 130px;
            transition: var(--transition-smooth);
        }

        .nav-select:hover {
            border-color: var(--accent-primary);
        }

        /* Right Side Nav */
        .nav-right {
            display: flex;
            align-items: center;
            gap: 1.75rem;
        }

        .nav-link {
            font-size: 0.8125rem;
            font-weight: 600;
            color: var(--text-main);
            text-decoration: none;
            transition: var(--transition-smooth);
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .nav-link:hover {
            color: var(--accent-primary);
        }

        .cart-pill {
            background: var(--midnight);
            color: #fff;
            padding: 0.5rem 1.125rem;
            border-radius: 99px;
            display: flex;
            align-items: center;
            gap: 0.625rem;
            font-size: 0.8125rem;
            font-weight: 700;
            text-decoration: none;
            transition: var(--transition-smooth);
            box-shadow: var(--shadow-sm);
        }

        .cart-pill:hover {
            background: var(--accent-primary);
            transform: translateY(-1px);
            box-shadow: var(--shadow-md);
        }

        .wish-pill {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 38px;
            height: 38px;
            border-radius: 50%;
            background: var(--bg-glass-input);
            border: 1px solid var(--border-bold);
            color: var(--midnight);
            text-decoration: none;
            transition: var(--transition-smooth);
            position: relative;
        }

        .wish-pill:hover {
            border-color: #ef4444;
            color: #ef4444;
            transform: translateY(-1px);
            background: rgba(239, 68, 68, 0.05);
        }

        .wish-badge {
            position: absolute;
            top: -5px;
            right: -5px;
            background: #ef4444;
            color: #fff;
            font-size: 0.65rem;
            font-weight: 800;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 2px solid #fff;
        }

        /* Wishlist Heart Icon Animation */
        .heart-btn {
            background: none;
            border: none;
            cursor: pointer;
            padding: 5px;
            color: #ef4444;
            transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        .heart-btn:hover { transform: scale(1.2); }
        .heart-btn:active { transform: scale(0.9); }
        .heart-btn svg {
            width: 20px;
            height: 20px;
            fill: none;
            stroke: currentColor;
            stroke-width: 2.2;
            transition: fill 0.3s ease;
        }
        .heart-btn.is-active svg {
            fill: #ef4444;
        }

        .user-trigger {
            font-weight: 700;
            font-size: 0.875rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            cursor: pointer;
            padding: 0.5rem;
            border-radius: 50%;
            background: var(--border-subtle);
            width: 32px;
            height: 32px;
            justify-content: center;
            transition: var(--transition-smooth);
        }

        .user-trigger:hover {
            background: var(--border-bold);
        }

        .user-dropdown {
            position: absolute;
            top: 100%;
            right: 0;
            background: #fff;
            border: 1px solid var(--border-bold);
            border-radius: 14px;
            box-shadow: var(--shadow-lg);
            width: 180px;
            padding: 0.5rem;
            margin-top: 0.75rem;
            opacity: 0;
            visibility: hidden;
            transform: translateY(10px);
            transition: var(--transition-smooth);
        }

        .user-menu:hover .user-dropdown {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }

        .dropdown-item {
            padding: 0.625rem 1rem;
            font-size: 0.875rem;
            font-weight: 500;
            border-radius: 8px;
            display: block;
            color: var(--text-main);
            text-decoration: none;
            transition: var(--transition-smooth);
        }

        .dropdown-item:hover {
            background: var(--border-subtle);
            color: var(--accent-primary);
        }

        /* --- Alerts --- */
        .alerts-container {
            position: fixed;
            top: 80px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 1500;
            width: 100%;
            max-width: 420px;
        }

        .alert {
            padding: 1rem 1.5rem;
            font-size: 0.875rem;
            font-weight: 500;
            border-radius: 14px;
            margin-bottom: 0.75rem;
            box-shadow: var(--shadow-lg);
            backdrop-filter: blur(8px);
            animation: fadeInUp 0.4s ease-out;
        }

        .alert-success {
            background: rgba(236, 253, 245, 0.9);
            color: #065f46;
            border: 1px solid #a7f3d0;
        }

        .alert-danger {
            background: rgba(254, 242, 242, 0.9);
            color: #991b1b;
            border: 1px solid #fecaca;
        }

        /* --- Layout --- */
        .main-content {
            padding-top: calc(var(--navbar-height) + 2rem);
            min-height: 70vh;
        }

        .site-footer {
            padding: 5rem 0 3rem;
            border-top: 1px solid var(--border-subtle);
            background: #fff;
        }

        .footer-logo {
            font-family: var(--font-elegant);
            color: var(--midnight);
            text-decoration: none;
        }

        .footer-links a {
            color: var(--text-muted);
            text-decoration: none;
            transition: var(--transition-smooth);
        }

        .footer-links a:hover {
            color: var(--accent-primary);
        }

        .footer-links {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
            padding: 0;
        }

        .footer-content {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 4rem;
        }

        .drawer {
            position: fixed;
            top: 0;
            right: -300px;
            width: 280px;
            height: 100vh;
            background: #fff;
            z-index: 2000;
            padding: 2rem;
            transition: right 0.3s ease;
        }

        .drawer-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.4);
            z-index: 1999;
        }

        body.menu-open .drawer {
            right: 0;
        }

        body.menu-open .drawer-overlay {
            display: block;
        }

        @@media (max-width: 1024px) {
            .nav-search-form {
                max-width: 400px;
            }

            .navbar {
                gap: 1rem;
            }
        }

        @@media (max-width: 768px) {

            .nav-search-form,
            .nav-links-desktop {
                display: none;
            }

            .menu-toggle {
                display: block;
            }
        }
    </style>
</head>

<body>
    <header class="site-header" id="header">
        <div class="container navbar">
            <a class="logo" asp-controller="Home" asp-action="Index">
                @ApplicationConfigurationManager.Instance.StoreName
            </a>

            <form id="liveFilterForm" method="get" asp-controller="Home" asp-action="Index" class="nav-search-form">
                <div class="search-input-wrap">
                    <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none"
                        stroke="currentColor" stroke-width="2.5">
                        <circle cx="11" cy="11" r="8"></circle>
                        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                    </svg>
                    <input type="text" name="searchQuery" id="navSearchInput"
                        value="@Context.Request.Query["searchQuery"]" placeholder="Find essentials..."
                        class="nav-search-input" autocomplete="off" />
                </div>

                <select name="categoryFilter" id="navCategorySelect" class="nav-select">
                    <option value="All">All Categories</option>
                    @inject OnlineStore.Application.Data.OnlineStoreDbContext _context
                    @{
                        var navCategories = _context.Categories.OrderBy(c => c.Name).ToList();
                    }
                    @foreach (var cat in navCategories)
                    {
                        <option value="@cat.Name" selected="@(Context.Request.Query["categoryFilter"] == cat.Name)">@cat.Name</option>
                    }
                </select>

                <select name="sortStrategy" id="navSortSelect" class="nav-select">
                    <option value="">Sort By</option>
                    <option value="PriceAsc" selected="@(Context.Request.Query["sortStrategy"] == "PriceAsc")">Price (Low to High)</option>
                    <option value="PriceDesc" selected="@(Context.Request.Query["sortStrategy"] == "PriceDesc")">Price (High to Low)</option>
                    <option value="Name" selected="@(Context.Request.Query["sortStrategy"] == "Name")">Alphabetical</option>
                    <option value="Stock" selected="@(Context.Request.Query["sortStrategy"] == "Stock")">Availability</option>
                </select>
                @* Preserve other filters if they exist in query *@
                @if (Context.Request.Query.ContainsKey("minPrice"))
                {
                    <input type="hidden" name="minPrice" value="@Context.Request.Query["minPrice"]" />
                }
                @if (Context.Request.Query.ContainsKey("maxPrice"))
                {
                    <input type="hidden" name="maxPrice" value="@Context.Request.Query["maxPrice"]" />
                }
            </form>

            <div class="nav-right">
                <nav class="nav-links-desktop" style="display: flex; gap: 1.5rem; align-items: center;">
                    <a class="nav-link" asp-controller="Home" asp-action="Index">Shop</a>
                    <a class="nav-link" asp-controller="Home" asp-action="OutOfStock" style="color: #ef4444; font-weight: 800;">Archive</a>

                    @{
                        var session = Context.Session;
                        var cart = session.Get<ShoppingCart>("Cart");
                        var count = cart?.Items.Sum(i => i.Quantity) ?? 0;
                        var username = session.GetString("Username");
                        
                        var wishlist = session.Get<List<Guid>>("Wishlist") ?? new List<Guid>();
                        var wishCount = wishlist.Count;
                    }
                    <a class="wish-pill" asp-controller="Wishlist" asp-action="Index" style="margin-right: -0.5rem;">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l8.72-8.72 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
                        </svg>
                        <span id="wishlist-badge" class="wish-badge" style="display: @(wishCount > 0 ? "flex" : "none")">@wishCount</span>
                    </a>

                    <a class="cart-pill" href="javascript:void(0)" onclick="openCart()">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2.5">
                            <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4H6z"></path>
                            <line x1="3" y1="6" x2="21" y2="6"></line>
                            <path d="M16 10a4 4 0 0 1-8 0"></path>
                        </svg>
                        <span>Cart @(count > 0 ? " • " + count : "")</span>
                    </a>

                    @if (!string.IsNullOrEmpty(username))
                    {
                        <div class="user-menu" style="position: relative;">
                            <div class="user-trigger">
                                @username.Substring(0, 1).ToUpper()
                                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="3">
                                    <path d="M6 9l6 6 6-6"></path>
                                </svg>
                            </div>
                            <div class="user-dropdown">
                                <a class="dropdown-item" asp-controller="Profile" asp-action="Index">Profile</a>
                                @{
                                    var userIdStr = session.GetString("UserId");
                                    if (!string.IsNullOrEmpty(userIdStr) && Guid.TryParse(userIdStr, out Guid userId))
                                    {
                                        var user = UserRepo.GetById(userId);
                                        if (user is Admin)
                                        {
                                            <a class="dropdown-item" asp-controller="Admin" asp-action="Index">Dashboard</a>
                                            <a class="dropdown-item" asp-controller="Home" asp-action="Catalog">Catalog Inventar</a>
                                        }
                                        else
                                        {
                                            <a class="dropdown-item" asp-controller="Orders" asp-action="MyOrders">Orders</a>
                                        }
                                    }
                                }
                                <a class="dropdown-item" style="color: #a4161a" asp-controller="Account"
                                    asp-action="Logout">Sign Out</a>
                            </div>
                        </div>
                    }
                    else
                    {
                        <a class="cart-pill" asp-controller="Account" asp-action="Login" style="background: transparent; border: 1.5px solid var(--midnight); color: var(--midnight);">Sign In</a>
                    }
                </nav>

                <button class="menu-toggle" onclick="toggleMenu()" style="display: none;">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="3" y1="12" x2="21" y2="12"></line>
                        <line x1="3" y1="6" x2="21" y2="6"></line>
                        <line x1="3" y1="18" x2="21" y2="18"></line>
                    </svg>
                </button>
            </div>
        </div>
    </header>

    @* Mobile Drawer remains similar but with smaller fonts *@
    <div class="drawer-overlay" onclick="toggleMenu()"></div>
    <div class="drawer">
        <div class="drawer-header">
            <button class="menu-toggle" onclick="toggleMenu()">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
        </div>
        <div style="margin-bottom: 2rem;">
            <form method="get" asp-controller="Home" asp-action="Index">
                <input type="text" name="searchQuery"
                    style="width: 100%; padding: 0.75rem; border-radius: 8px; border: 1px solid var(--border-light);"
                    placeholder="Search..." />
            </form>
        </div>
        <nav class="drawer-links">
            <a class="drawer-link" style="font-size: 1.125rem;" asp-controller="Home" asp-action="Index">Shop</a>
            <a class="drawer-link" style="font-size: 1.125rem;" asp-controller="Cart" asp-action="Index">Cart
                (@count)</a>
            @if (!string.IsNullOrEmpty(username))
            {
                var userIdStr = session.GetString("UserId");
                if (!string.IsNullOrEmpty(userIdStr) && Guid.TryParse(userIdStr, out Guid userId))
                {
                    var user = UserRepo.GetById(userId);
                    if (user is Admin)
                    {
                        <a class="drawer-link" style="font-size: 1.125rem;" asp-controller="Home" asp-action="Catalog">Catalog
                            Inventar</a>
                    }
                }
                <a class="drawer-link" style="font-size: 1.125rem;" asp-controller="Profile" asp-action="Index">Profile</a>
                <a class="drawer-link" style="font-size: 1.125rem; color: #a4161a" asp-controller="Account"
                    asp-action="Logout">Sign Out</a>
            }
            else
            {
                <a class="drawer-link" style="font-size: 1.125rem;" asp-controller="Account" asp-action="Login">Sign In</a>
                <a class="drawer-link" style="font-size: 1.125rem;" asp-controller="Account" asp-action="Register">Join
                    Us</a>
            }
        </nav>
    </div>

    <div class="alerts-container">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }
    </div>

    <main role="main" class="main-content">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container footer-content" style="font-size: 0.8125rem;">
            <div>
                <a class="footer-logo" style="font-size: 1.25rem;" asp-controller="Home"
                    asp-action="Index">@ApplicationConfigurationManager.Instance.StoreName</a>
                <p style="color: var(--text-muted); max-width: 240px">Curated essentials for the modern home. Quality
                    over quantity, always.</p>
            </div>
            <div style="display: flex; gap: 4rem;">
                <ul class="footer-links">
                    <li><span style="font-weight: 700; color: var(--text-dark)">Navigate</span></li>
                    <li><a asp-controller="Home" asp-action="Index">Shop All</a></li>
                    <li><a asp-controller="Home" asp-action="Privacy">Privacy</a></li>
                </ul>
                <ul class="footer-links">
                    <li><span style="font-weight: 700; color: var(--text-dark)">Account</span></li>
                    <li><a asp-controller="Cart" asp-action="Index">Cart</a></li>
                    <li><a asp-controller="Profile" asp-action="Index">Settings</a></li>
                </ul>
            </div>
        </div>
        <div class="container"
            style="margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid var(--border-light); font-size: 0.75rem; color: var(--text-muted); text-align: center;">
            &copy; 2026 @ApplicationConfigurationManager.Instance.StoreName. Fine Goods.
        </div>
    </footer>

    <!-- Side Cart Drawer Shell -->
    <div class="drawer-overlay" id="cartOverlay" onclick="document.body.classList.remove('cart-open')"></div>
    <div class="cart-drawer-wrapper">
        <div style="padding: 1.5rem; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-subtle);">
            <h2 style="font-family: var(--font-elegant); font-size: 1.75rem; color: var(--midnight); margin: 0;">Coșul tău</h2>
            <button onclick="document.body.classList.remove('cart-open')" style="background: none; border: none; font-size: 2rem; cursor: pointer; color: var(--text-muted);">&times;</button>
        </div>
        <div id="cartDrawerBody" style="flex: 1; position: relative;">
            <div style="padding: 2rem; text-align: center; color: var(--text-muted);">Se încarcă coșul...</div>
        </div>
    </div>

    <script>
        function toggleMenu() { document.body.classList.toggle('menu-open'); }

        // Live Filtering Logic
        const filterForm = document.getElementById('liveFilterForm');
        const searchInput = document.getElementById('navSearchInput');
        const categorySelect = document.getElementById('navCategorySelect');
        const sortSelect = document.getElementById('navSortSelect');

        let debounceTimer;
        const debounceSubmit = () => {
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(() => {
                filterForm.submit();
            }, 400);
        };

        if (searchInput) {
            searchInput.addEventListener('input', debounceSubmit);
            // Focus at end of text on load if search was active
            if (searchInput.value) {
                searchInput.focus();
                searchInput.setSelectionRange(searchInput.value.length, searchInput.value.length);
            }
        }

        if (categorySelect) {
            categorySelect.addEventListener('change', () => filterForm.submit());
        }

        if (sortSelect) {
            sortSelect.addEventListener('change', () => filterForm.submit());
        }

        // Theme Toggle Logic
        const themeBtn = document.getElementById('themeToggle');
        const sunIcon = document.querySelector('.sun-icon');
        const moonIcon = document.querySelector('.moon-icon');

        function updateIcons() {
            if (document.documentElement.classList.contains('dark-theme')) {
                if (sunIcon) sunIcon.style.display = 'block';
                if (moonIcon) moonIcon.style.display = 'none';
            } else {
                if (sunIcon) sunIcon.style.display = 'none';
                if (moonIcon) moonIcon.style.display = 'block';
            }
        }

        if (themeBtn) {
            updateIcons();
            themeBtn.addEventListener('click', () => {
                document.documentElement.classList.toggle('dark-theme');
                const isDark = document.documentElement.classList.contains('dark-theme');
                localStorage.setItem('theme', isDark ? 'dark' : 'light');
                updateIcons();
            });
        }

        // Side-Cart Logic
        async function openCart() {
            document.body.classList.add('cart-open');
            const drawerBody = document.getElementById('cartDrawerBody');
            drawerBody.innerHTML = '<div style="padding: 2rem; text-align: center; color: var(--text-muted);">Se încarcă coșul...</div>';
            
            try {
                const response = await fetch('/Cart/GetCartPartial');
                const html = await response.text();
                drawerBody.innerHTML = html;
            } catch(e) { console.error(e); }
        }

        async function updateQty(adjustment, productId, size, color) {
            const sizeStr = size || '';
            const colorStr = color || '';
            const key = (productId + '_' + sizeStr + '_' + colorStr).replace(/-/g, '').replace(/ /g, '');
            const qtySpan = document.getElementById('qty-' + key);
            if(!qtySpan) return;
            const currentQty = parseInt(qtySpan.innerText);
            const newQty = currentQty + adjustment;

            if (newQty < 1) return;

            const formData = new FormData();
            formData.append('id', productId);
            formData.append('quantity', newQty);
            if(sizeStr) formData.append('size', sizeStr);
            if(colorStr) formData.append('color', colorStr);

            try {
                const response = await fetch('/Cart/UpdateQuantity', { method: 'POST', body: formData });
                const result = await response.json();
                if (result.success) {
                    openCart(); // Reload drawer
                } else {
                    alert(result.message || "Eroare la actualizarea cantității.");
                }
            } catch (e) { console.error(e); }
        }

        // Intercept Add to Cart forms globally
        document.addEventListener('submit', async (e) => {
            const form = e.target;
            if (form.getAttribute('action') && form.getAttribute('action').includes('/Cart/Add')) {
                e.preventDefault();
                const btn = form.querySelector('button[type="submit"]');
                const ogText = btn ? btn.innerHTML : '';
                if(btn) btn.innerHTML = 'Adăugare...';
                
                const formData = new FormData(form);
                try {
                    const response = await fetch('/Cart/AddAjax', { method: 'POST', body: formData });
                    const result = await response.json();
                    if (result.success) {
                        const pillCountSpan = document.querySelector('.cart-pill span');
                        if(pillCountSpan) pillCountSpan.innerHTML = 'Cart ' + (result.cartCount > 0 ? " • " + result.cartCount : "");
                        openCart();
                    } else {
                        alert(result.message || "Nu s-a putut adăuga.");
                    }
                } catch(err) { 
                    console.error(err); 
                    form.submit(); 
                }
                finally { if(btn) btn.innerHTML = ogText; }
            }
        });

        // Wishlist Logic
        async function toggleFavorite(productId, btn) {
            try {
                const response = await fetch('/Wishlist/Toggle?id=' + productId, { method: 'POST' });
                const result = await response.json();
                if (result.success) {
                    if (result.added) {
                        btn.classList.add('is-active');
                    } else {
                        btn.classList.remove('is-active');
                    }
                    updateWishlistBadge(result.count);
                }
            } catch (e) { console.error('Wishlist toggle failed', e); }
        }

        function updateWishlistBadge(count) {
            const badge = document.getElementById('wishlist-badge');
            if (!badge) return;
            badge.innerText = count;
            badge.style.display = count > 0 ? 'flex' : 'none';
        }

        // Alert auto-dismiss
        setTimeout(() => {
            document.querySelectorAll('.alert').forEach(a => {
                a.style.opacity = '0';
                a.style.transform = 'translateY(-10px)';
                a.style.transition = '0.4s';
                setTimeout(() => a.remove(), 400);
            });
        }, 3000);
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
